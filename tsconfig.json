{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@src/*": ["packages/@ooc/core/*"],
      "@ooc/core/*": ["packages/@ooc/core/*"],
      "@ooc/builtins/agent/plan/*": ["packages/@ooc/builtins/agent/children/plan/*"],
      "@ooc/builtins/agent/pr/*": ["packages/@ooc/builtins/agent/children/pr/*"],
      "@ooc/builtins/agent/thread/*": ["packages/@ooc/builtins/agent/children/thread/*"],
      "@ooc/builtins/agent/skill_index/*": ["packages/@ooc/builtins/agent/children/skill_index/*"],
      "@ooc/builtins/agent/todo/*": ["packages/@ooc/builtins/agent/children/todo/*"],
      "@ooc/builtins/agent/method_exec_form/*": ["packages/@ooc/builtins/agent/children/method_exec_form/*"],
      "@ooc/builtins/interpreter/interpreter_process/*": ["packages/@ooc/builtins/interpreter/children/interpreter_process/*"],
      "@ooc/builtins/terminal/terminal_process/*": ["packages/@ooc/builtins/terminal/children/terminal_process/*"],
      "@ooc/builtins/filesystem/file/*": ["packages/@ooc/builtins/filesystem/children/file/*"],
      "@ooc/builtins/filesystem/search/*": ["packages/@ooc/builtins/filesystem/children/search/*"],
      "@ooc/builtins/knowledge_base/knowledge/*": ["packages/@ooc/builtins/knowledge_base/children/knowledge/*"],
      "@ooc/builtins/feishu_app/feishu_chat/*": ["packages/@ooc/builtins/feishu_app/children/feishu_chat/*"],
      "@ooc/builtins/feishu_app/feishu_doc/*": ["packages/@ooc/builtins/feishu_app/children/feishu_doc/*"],
      "@ooc/builtins/agent/plan": ["packages/@ooc/builtins/agent/children/plan/index.ts"],
      "@ooc/builtins/agent/pr": ["packages/@ooc/builtins/agent/children/pr/index.ts"],
      "@ooc/builtins/agent/thread": ["packages/@ooc/builtins/agent/children/thread/index.ts"],
      "@ooc/builtins/agent/skill_index": ["packages/@ooc/builtins/agent/children/skill_index/index.ts"],
      "@ooc/builtins/agent/todo": ["packages/@ooc/builtins/agent/children/todo/index.ts"],
      "@ooc/builtins/agent/method_exec_form": ["packages/@ooc/builtins/agent/children/method_exec_form/index.ts"],
      "@ooc/builtins/interpreter/interpreter_process": ["packages/@ooc/builtins/interpreter/children/interpreter_process/index.ts"],
      "@ooc/builtins/terminal/terminal_process": ["packages/@ooc/builtins/terminal/children/terminal_process/index.ts"],
      "@ooc/builtins/filesystem/file": ["packages/@ooc/builtins/filesystem/children/file/index.ts"],
      "@ooc/builtins/filesystem/search": ["packages/@ooc/builtins/filesystem/children/search/index.ts"],
      "@ooc/builtins/knowledge_base/knowledge": ["packages/@ooc/builtins/knowledge_base/children/knowledge/index.ts"],
      "@ooc/builtins/feishu_app/feishu_chat": ["packages/@ooc/builtins/feishu_app/children/feishu_chat/index.ts"],
      "@ooc/builtins/feishu_app/feishu_doc": ["packages/@ooc/builtins/feishu_app/children/feishu_doc/index.ts"],
      "@ooc/builtins/*": ["packages/@ooc/builtins/*"],
      "@ooc/web/*": ["packages/@ooc/web/src/*"],
      "@ooc/storybook/*": ["packages/@ooc/storybook/*"],
      "@ooc/tests/*": ["packages/@ooc/tests/*"]
    },
    "types": ["bun", "node"],
    "skipLibCheck": true
  },
  "include": [
    "packages/@ooc/core/**/*.ts",
    "packages/@ooc/storybook/**/*.ts",
    "packages/@ooc/tests/**/*.ts",
    "packages/*/**/*.ts",
    "packages/*/**/*.tsx"
  ]
}
