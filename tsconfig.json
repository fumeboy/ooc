{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@meta": ["meta/index.doc.js"],
      "@meta/*": ["meta/*"],
      "@src/*": ["src/*"]
    },
    "types": ["bun", "node"],
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "meta/**/*.js",
    "meta/**/*.ts",
    "tests/**/*.ts",
    "stones/**/*.ts",
    "stones/**/*.tsx",
    ".ooc-world/stones/**/*.ts"
  ],
  "exclude": [
    "web"
  ]
}
