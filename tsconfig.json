{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@meta": ["packages/@ooc/meta/index.doc.js"],
      "@meta/*": ["packages/@ooc/meta/*"],
      "@src/*": ["packages/@ooc/core/*"],
      "@ooc/core/*": ["packages/@ooc/core/*"],
      "@ooc/builtins/*": ["packages/@ooc/builtins/*"],
      "@ooc/web/*": ["packages/@ooc/web/src/*"],
      "@ooc/meta/*": ["packages/@ooc/meta/*"],
      "@ooc/tests/*": ["packages/@ooc/tests/*"]
    },
    "types": ["bun", "node"],
    "skipLibCheck": true
  },
  "include": [
    "packages/@ooc/core/**/*.ts",
    "packages/@ooc/meta/**/*.js",
    "packages/@ooc/meta/**/*.ts",
    "packages/@ooc/tests/**/*.ts",
    "packages/*/**/*.ts",
    "packages/*/**/*.tsx"
  ]
}
