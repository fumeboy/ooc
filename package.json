{
  "name": "ooc-workspace",
  "type": "module",
  "private": true,
  "workspaces": ["packages/**", "packages/**/children/**"],
  "scripts": {
    "test": "bun test",
    "check:tsc": "bash scripts/check-tsc.sh",
    "check:silent-swallow": "bash scripts/check-no-silent-swallow.sh",
    "check:deprecated-symbols": "bash scripts/check-no-deprecated-symbols.sh",
    "check:doc-drift": "bash scripts/check-doc-deprecated-drift.sh",
    "check:anchor-drift": "bash scripts/check-doc-anchor-drift.sh",
    "verify": "bun run check:tsc && bun test packages/@ooc/tests/ && bun run check:silent-swallow && bun run check:deprecated-symbols && bun run check:doc-drift && bun run check:anchor-drift",
    "dev:server": "bun run packages/@ooc/core/app/server/index.ts",
    "dev:web": "bun --bun vite packages/@ooc/web"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.9.0",
    "vite": "^7.1.13"
  },
  "dependencies": {
    "@ooc/core": "workspace:*",
    "@ooc/web": "workspace:*",
    "elysia": "^1.4.28",
    "js-yaml": "^4.1.1",
    "openai": "^6.37.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
