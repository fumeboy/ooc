{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@src/*": ["../src/*"],
      "@ooc/core/*": ["../core/*"],
      // builtin <family>/<child> 子包映射镜像根 tsconfig.json（vite-tsconfig-paths 读本文件；
      // 不能靠 install 生成的 children 符号链接，rollup 不跟随）。新增 builtin child 时此处与根 tsconfig 须成对更新。
      "@ooc/builtins/agent/plan/*": ["../builtins/agent/children/plan/*"],
      "@ooc/builtins/agent/pr/*": ["../builtins/agent/children/pr/*"],
      "@ooc/builtins/agent/thread/*": ["../builtins/agent/children/thread/*"],
      "@ooc/builtins/agent/skill_index/*": ["../builtins/agent/children/skill_index/*"],
      "@ooc/builtins/agent/todo/*": ["../builtins/agent/children/todo/*"],
      "@ooc/builtins/agent/method_exec_form/*": ["../builtins/agent/children/method_exec_form/*"],
      "@ooc/builtins/interpreter/interpreter_process/*": ["../builtins/interpreter/children/interpreter_process/*"],
      "@ooc/builtins/terminal/terminal_process/*": ["../builtins/terminal/children/terminal_process/*"],
      "@ooc/builtins/filesystem/file/*": ["../builtins/filesystem/children/file/*"],
      "@ooc/builtins/filesystem/search/*": ["../builtins/filesystem/children/search/*"],
      "@ooc/builtins/knowledge_base/knowledge/*": ["../builtins/knowledge_base/children/knowledge/*"],
      "@ooc/builtins/feishu_app/feishu_chat/*": ["../builtins/feishu_app/children/feishu_chat/*"],
      "@ooc/builtins/feishu_app/feishu_doc/*": ["../builtins/feishu_app/children/feishu_doc/*"],
      "@ooc/builtins/*": ["../builtins/*"]
    }
  },
  "include": ["src"]
}

