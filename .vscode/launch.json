{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Server",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/server",
            "args": [
                "-config", ".conf.xml",
                "-port", "8080",
                "-debug"
            ],
            "env": {},
            "cwd": "${workspaceFolder}",
            "showLog": true,
            "trace": "verbose"
        },
        {
            "name": "Debug Server (No Debug Flag)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/server",
            "args": [
                "-config", ".conf.xml",
                "-port", "8080"
            ],
            "env": {},
            "cwd": "${workspaceFolder}",
            "showLog": true
        },
        {
            "name": "Attach to Server",
            "type": "go",
            "request": "attach",
            "mode": "local",
            "processId": 0
        }
    ]
}